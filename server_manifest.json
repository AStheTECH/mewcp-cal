  "tools": {
    "groups": {
      "availability": {
        "file": "availability_tools.py",
        "doc_source": "",
        "register_fn": "register_availability_tools",
        "tools": {
          "get_availability": {
            "endpoint": "GET /availability",
            "description": "Get available time slots",
            "tier": "GET",
            "params": [
              {
                "name": "date",
                "type": "str",
                "required": true,
                "description": "Date in YYYY-MM-DD format"
              }
            ],
            "response_fields": [
              {
                "name": "date",
                "type": "str"
              },
              {
                "name": "timeZone",
                "type": "str"
              },
              {
                "name": "count",
                "type": "int"
              },
              {
                "name": "slots",
                "type": "list[SlotData]"
              },
              {
                "name": "slots[].start",
                "type": "str"
              },
              {
                "name": "slots[].end",
                "type": "str"
              },
              {
                "name": "slots[].time",
                "type": "str"
              },
              {
                "name": "slots[].attendees",
                "type": "int"
              },
              {
                "name": "slots[].bookingUid",
                "type": "str"
              }
            ],
            "schema": {
              "data": "AvailabilityData",
              "result": "AvailabilityResult"
            }
          },
          "get_busy_times": {
            "endpoint": "GET /busy-times",
            "description": "Get busy times from calendars",
            "tier": "GET",
            "params": [],
            "response_fields": [
              {
                "name": "count",
                "type": "int"
              },
              {
                "name": "busy_times",
                "type": "list[BusyTimeData]"
              },
              {
                "name": "busy_times[].start",
                "type": "str"
              },
              {
                "name": "busy_times[].end",
                "type": "str"
              },
              {
                "name": "busy_times[].source",
                "type": "str"
              },
              {
                "name": "busy_times[].title",
                "type": "str"
              }
            ],
            "schema": {
              "data": "BusyTimeListData",
              "result": "BusyTimeListResult"
            }
          }
        }
      },
