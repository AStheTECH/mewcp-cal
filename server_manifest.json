                "required": true,
                "description": "The booking ID to retrieve"
              }
            ],
            "response_fields": [
              {
                "name": "id",
                "type": "int"
              },
              {
                "name": "uid",
                "type": "str"
              },
              {
                "name": "title",
                "type": "str"
              },
              {
                "name": "description",
                "type": "str"
              },
              {
                "name": "status",
                "type": "str"
              },
              {
                "name": "start",
                "type": "str"
              },
              {
                "name": "end",
                "type": "str"
              },
              {
                "name": "duration",
                "type": "int"
              },
              {
                "name": "eventTypeId",
                "type": "int"
              },
