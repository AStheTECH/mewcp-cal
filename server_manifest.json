                "name": "hosts",
                "type": "list[dict]"
              }
            ],
            "schema": {
              "data": "BookingData",
              "result": "BookingResult"
            }
          },
          "create_booking": {
            "endpoint": "POST /bookings",
            "description": "Create a new booking",
            "tier": "CREATE",
            "params": [
              {
                "name": "event_type_id",
                "type": "int",
                "required": true,
                "description": "Event type ID"
              },
              {
                "name": "start",
                "type": "str",
                "required": true,
                "description": "Booking start datetime"
              },
              {
                "name": "attendee_name",
                "type": "str",
                "required": true,
                "description": "Attendee full name"
              },
              {
                "name": "attendee_email",
                "type": "str",
                "required": true,
                "description": "Attendee email address"
              }
            ],
            "response_fields": [
              {
                "name": "id",
                "type": "int"
              },
              {
                "name": "uid",
                "type": "str"
              },
              {
                "name": "title",
                "type": "str"
              },
              {
                "name": "status",
                "type": "str"
              },
              {
                "name": "start",
                "type": "str"
              },
              {
                "name": "end",
                "type": "str"
              },
              {
                "name": "eventTypeId",
                "type": "int"
              },
              {
                "name": "meetingUrl",
                "type": "str"
              },
              {
                "name": "attendees",
                "type": "list[BookingAttendeeData]"
              }
            ],
            "schema": {
              "data": "BookingData",
              "result": "BookingCreateResult"
            }
          },
          "cancel_booking": {
            "endpoint": "POST /bookings/{booking_id}/cancel",
            "description": "DESTRUCTIVE \u2014 REQUIRES EXPLICIT USER CONFIRMATION BEFORE CALLING. Cancel a booking; permanently cancels the booking and returns its state before cancellation.",
            "tier": "DELETE",
            "params": [
              {
                "name": "booking_id",
                "type": "str",
                "required": true,
                "description": "The booking ID to cancel"
              }
            ],
            "response_fields": [
              {
                "name": "before",
                "type": "BookingData"
              },
              {
                "name": "after",
                "type": "BookingData"
              }
            ],
            "schema": {
              "data": "BookingCancelData",
              "result": "BookingCancelResult"
            }
          },
          "reschedule_booking": {
            "endpoint": "POST /bookings/{booking_id}/reschedule",
            "description": "Reschedule an existing booking; returns both the before and after state.",
            "tier": "UPDATE",
            "params": [
              {
                "name": "booking_id",
                "type": "str",
                "required": true,
                "description": "The booking ID to reschedule"
              },
              {
                "name": "start",
                "type": "str",
                "required": true,
                "description": "New start time"
              },
              {
                "name": "end",
                "type": "str",
                "required": true,
                "description": "New end time"
              }
            ],
            "response_fields": [
              {
                "name": "before",
                "type": "BookingData"
              },
              {
                "name": "after",
                "type": "BookingData"
              }
            ],
            "schema": {
              "data": "BookingUpdateData",
              "result": "BookingRescheduleResult"
            }
          },
          "confirm_booking": {
            "endpoint": "POST /bookings/{booking_id}/confirm",
            "description": "Confirm a pending booking; returns both the before and after state.",
            "tier": "UPDATE",
            "params": [
              {
                "name": "booking_id",
                "type": "str",
                "required": true,
                "description": "Booking ID"
              }
            ],
            "response_fields": [
              {
                "name": "before",
                "type": "BookingData"
              },
              {
                "name": "after",
                "type": "BookingData"
              }
            ],
            "schema": {
              "data": "BookingUpdateData",
              "result": "BookingConfirmResult"
            }
          },
          "mark_booking_absent": {
            "endpoint": "POST /bookings/{booking_id}/absence",
            "description": "Mark a booking as absent; returns both the before and after state.",
            "tier": "UPDATE",
            "params": [
              {
                "name": "booking_id",
                "type": "str",
                "required": true,
